AUTH_API_MFA_TOTP_DIGITS=6
AUTH_API_MFA_TOTP_PERIOD=30s
AUTH_API_MFA_TOTP_ALLOWED_DRIFT_WINDOWS=1
AUTH_API_STEP_UP_MAX_AGE=10m
AUTH_API_WEB_ORIGIN=http://localhost:3000
AUTH_API_WEB_ALT_ORIGIN=http://localhost:5173
AUTH_API_REFRESH_COOKIE_NAME=authapi_refresh_token
AUTH_API_REFRESH_COOKIE_SECURE=false
