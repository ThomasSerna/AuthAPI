AUTH_API_JWT_REFRESH_TOKEN_TTL=30d
AUTH_API_EMAIL_VERIFICATION_TOKEN_TTL=24h
AUTH_API_EMAIL_VERIFICATION_URL_TEMPLATE=http://localhost:8080/verify-email?token={token}
AUTH_API_PASSWORD_RESET_TOKEN_TTL=1h
AUTH_API_PASSWORD_RESET_URL_TEMPLATE=http://localhost:8080/reset-password?token={token}
AUTH_API_PASSWORD_RESET_REQUEST_MIN_RESPONSE_TIME=400ms
AUTH_API_PASSWORD_RESET_MIN_RESPONSE_TIME=400ms
AUTH_API_MAIL_ENABLED=false
AUTH_API_MAIL_FROM_EMAIL=noreply@authapi.com
AUTH_API_MAIL_FROM_NAME=AuthApi
AUTH_API_MAIL_REPLY_TO=
SPRING_MAIL_HOST=
SPRING_MAIL_PORT=587
SPRING_MAIL_USERNAME=
SPRING_MAIL_PASSWORD=
SPRING_MAIL_PROPERTIES_MAIL_SMTP_AUTH=true
SPRING_MAIL_PROPERTIES_MAIL_SMTP_STARTTLS_ENABLE=true
SPRING_MAIL_PROPERTIES_MAIL_SMTP_CONNECTIONTIMEOUT=5000
SPRING_MAIL_PROPERTIES_MAIL_SMTP_TIMEOUT=5000
SPRING_MAIL_PROPERTIES_MAIL_SMTP_WRITETIMEOUT=5000
AUTH_API_MFA_TOTP_ISSUER=AuthApi
